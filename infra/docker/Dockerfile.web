# Multi-stage Dockerfile for `apps/web`.
#
# R3.5 — build-time `VITE_SERVER_URL` selects between local-only and
# server modes. **Vite inlines this value at build time**, so it MUST
# be supplied as a `--build-arg` to `docker build` (or as the matching
# key in docker-compose's `build.args` block). Leaving it unset / empty
# produces the local-only bundle (no Login / Logout / Account chrome).
#
# R8.2 (2026-07-08) — runtime stage switched from `vite preview` on a
# full Node runtime to `nginx:alpine` serving the static build. Drops
# the base image from ~170 MB (node:22-alpine + corepack + yarn) to
# ~8 MB (nginx:alpine), and drops the entire workspace `node_modules`
# from the runtime image (~490 MB → 0). Net: ~684 MB → ~15 MB.
#
# Build manually:
#   docker build \
#     -f infra/docker/Dockerfile.web \
#     --build-arg VITE_SERVER_URL=https://dnd.example.com \
#     -t dnd-inv-web ../..
#
# Build via compose: set `VITE_SERVER_URL` in `infra/docker/.env`; the
# compose file passes it through to this stage's `ARG`.

# ---------- Stage 1: builder ----------
FROM node:22-alpine AS build
RUN corepack enable && corepack prepare pnpm@11.8.0 --activate

WORKDIR /repo

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json tsconfig.base.json tsconfig.json ./
COPY apps/server/package.json apps/server/
COPY apps/web/package.json apps/web/
COPY packages/rules/package.json packages/rules/
COPY packages/seeds/package.json packages/seeds/
COPY packages/shared/package.json packages/shared/

RUN pnpm install --frozen-lockfile

COPY packages/ packages/
COPY apps/web/ apps/web/

# R3.5 — mode flag. Unset → local-only build (today's MVP UX). Set to
# a fully-qualified origin (e.g. https://dnd.example.com) → server-mode
# bundle. Vite reads this from `process.env.VITE_SERVER_URL` at build
# time and inlines it into the bundle (see
# apps/web/src/lib/serverMode.ts). Default empty keeps `docker compose
# up` a friendly local-only build for first-time setup.
ARG VITE_SERVER_URL=""
ENV VITE_SERVER_URL=$VITE_SERVER_URL

RUN pnpm --filter @app/web build

# ---------- Stage 2: runtime ----------
# nginx:alpine is ~8 MB. The final image contains only the static bundle
# (`dist/`) + the SPA-mode nginx config. No Node runtime, no pnpm, no
# workspace node_modules.
FROM nginx:alpine AS runtime

# SPA history-mode fallback: any path that doesn't match a real file
# gets rewritten to /index.html so React Router can handle client-side
# routing. Without this, direct navigation to /party/:id/* returns 404.
COPY infra/docker/nginx.conf /etc/nginx/conf.d/default.conf

# The vite build output is a plain static bundle. `/usr/share/nginx/html`
# is the default docroot in `nginx:alpine`, so `try_files` picks up
# assets by relative path (`/assets/index-abcd.js`) automatically.
COPY --from=build /repo/apps/web/dist /usr/share/nginx/html

EXPOSE 80
# `nginx:alpine`'s default CMD is `nginx -g 'daemon off;'`, which is
# exactly what we want (foreground for docker's PID 1). No override
# needed.
