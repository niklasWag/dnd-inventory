# R3.1 docker-compose env file — DEV DEFAULTS ONLY.
# Copy to `.env` and adjust for your setup. Production deployments MUST
# override every value here — generate strong values for POSTGRES_PASSWORD
# and AUTH_SECRET. Never commit a real production .env.
#
# Local dev quick-start (recommended): brings up the same-origin Caddy
# proxy AND the Mailpit SMTP capture UI so login flows work out of the
# box against http://localhost:8080.
#   cd infra/docker
#   cp .env.example .env
#   docker compose --profile proxy --profile mail up --build

# Postgres
POSTGRES_USER=dnd
POSTGRES_PASSWORD=dnd
POSTGRES_DB=dnd_inv
# Host-side port; non-standard to avoid clashing with a host installation.
POSTGRES_PORT=5433

# Server
SERVER_PORT=3000

# Web
WEB_PORT=5173

# R3.5 — Optional same-origin reverse proxy. The `caddy` compose service
# (profiles: [proxy]) listens on this host port and routes /auth/*,
# /sync/*, /parties/*, /socket.io/*, /healthz to the server and everything
# else to the web. Only runs when started with `docker compose --profile
# proxy up`. Used for local Docker Desktop testing of the auth flow
# (cross-origin SameSite=Lax cookies don't work without a same-origin
# front door). Production deployments behind a host nginx leave the
# profile off and proxy directly to ${SERVER_PORT} + ${WEB_PORT} on the
# compose host.
PROXY_PORT=8080

# R3.5 — `WEB_ORIGIN` is the public origin the SPA is served from. The
# server's CORS allow-origin + the Auth.js redirect whitelist + the
# R5.1 Socket.IO CORS all gate on this value, and `SameSite=Lax` session
# cookies require the SPA's fetch to come from the same host as the
# cookie was set on. Three typical values:
#   - Compose with the proxy profile: `http://localhost:${PROXY_PORT}`
#     (default 8080). All traffic flows through Caddy → same origin.
#   - Compose without the proxy + host nginx in front: the public domain
#     (`https://dnd.example.com`).
#   - Compose without any proxy: `http://localhost:${WEB_PORT}` (5173).
#     This is fine for the local-only MVP but BREAKS server-mode auth
#     because the web fetches the server cross-origin.
WEB_ORIGIN=http://localhost:8080

# R3.5 — Web bundle mode. Empty (the default) builds the web container
# in LOCAL-ONLY mode: no Login / Logout / Account / Linked accounts
# chrome appears in the UI, identical to the pre-server MVP behavior.
# Setting this to a fully-qualified origin (e.g. `https://dnd.example.com`)
# at `docker compose build` time produces a SERVER-MODE bundle that
# points the web client at that origin. The value is INLINED into the
# JS bundle by Vite — changing it requires `docker compose build web`
# (a plain `docker compose up` will keep serving the previous build).
#
# Must be SAME ORIGIN as WEB_ORIGIN in production (the session cookie
# is SameSite=Lax; R5.1 WebSocket transport reuses the same cookie).
# With the compose `--profile proxy` setup this is
# `http://localhost:${PROXY_PORT}`. In a reverse-proxy deployment the
# value typically matches the public domain.
VITE_SERVER_URL=http://localhost:8080

# R3.2 — Auth.js (Discord OAuth + email OTP + DB sessions).
# Required at all times (Auth.js refuses to start without it).
# Generate a 32+ byte random secret: `openssl rand -base64 32`.
# Rotating this invalidates ALL existing sessions per SECURITY §1.1.
AUTH_SECRET="dev-only-replace-me-with-openssl-rand-base64-32-XXXXXXXXX"

# R3.5 — Drop the `__Host-` cookie prefix + Secure flag in production. Set
# to `true` ONLY for self-hosted deployments served over plain HTTP (the
# default docker compose `--profile proxy` setup on http://localhost:8080
# is exactly this case). Without this, browsers silently refuse to store
# the session cookie on HTTP and users appear logged-out after every
# request. Real production HTTPS deployments MUST leave this blank/false.
SESSION_COOKIE_INSECURE=true

# Discord application credentials. Leave blank to disable the
# /auth/discord/* routes (they return 503) — the web Login button is
# hidden via the `GET /auth/methods` probe. In production the server
# logs a startup warning listing the missing vars but boots successfully.
#
# IMPORTANT: the redirect URI is HARDCODED by Auth.js as
# `${basePath}/callback/${providerId}` → `/auth/callback/discord`
# (see apps/server/src/auth/routes.ts). Register this EXACT URL in the
# Discord developer portal's OAuth2 → Redirects list, along with the
# link-flow URL `/auth/callback/discord/link` (R3.5).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback/discord

# R3.3 — Email OTP via SMTP. Wired to the Mailpit service in the `mail`
# compose profile — start it with:
#   docker compose --profile proxy --profile mail up
# Captured mail is browseable at http://localhost:${MAILPIT_UI_PORT}.
#
# Same opt-in pattern as Discord: leave any of the five blank to disable
# the /auth/email/* routes (they return 503). Production options:
#   - Postmark / SendGrid / SES / Mailgun (set their SMTP submission host
#     + the API-key credentials they hand you)
#   - Self-hosted Postfix on the same box
#
# Mailpit accepts ANY credentials by default (no real auth). We still
# have to set SMTP_USER/PASS to non-empty values because the server's
# env schema requires all five to be set together in production mode
# (apps/server/src/config/env.ts). The actual values are irrelevant —
# pick anything. SMTP_FROM must parse as a real email (TLD required) —
# `.local` satisfies the email regex without resolving in DNS.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASS=dev
SMTP_FROM=dnd-inv@dnd-inv.local

# Mailpit host ports (optional overrides; defaults match compose).
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# R3.4.b — nightly snapshot job. Files land in SNAPSHOT_DIR; mount it
# as a docker volume so they survive container restarts. The compose
# file does this automatically when this var is set.
SNAPSHOTS_ENABLED=true
SNAPSHOT_DIR=/data/snapshots
SNAPSHOT_RETENTION_DAYS=30
