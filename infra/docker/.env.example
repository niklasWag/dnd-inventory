# R3.1 docker-compose env file — DEV DEFAULTS ONLY.
# Production deployments MUST override every value here. Generate strong
# values for POSTGRES_PASSWORD; never commit a real production .env.

# Postgres
POSTGRES_USER=dnd
POSTGRES_PASSWORD=dnd
POSTGRES_DB=dnd_inv
# Host-side port; non-standard to avoid clashing with a host installation.
POSTGRES_PORT=5433

# Server
SERVER_PORT=3000

# Web
WEB_PORT=5173
