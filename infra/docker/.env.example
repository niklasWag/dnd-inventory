# R3.1 docker-compose env file — DEV DEFAULTS ONLY.
# Production deployments MUST override every value here. Generate strong
# values for POSTGRES_PASSWORD; never commit a real production .env.

# Postgres
POSTGRES_USER=dnd
POSTGRES_PASSWORD=dnd
POSTGRES_DB=dnd_inv
# Host-side port; non-standard to avoid clashing with a host installation.
POSTGRES_PORT=5433

# Server
SERVER_PORT=3000

# Web
WEB_PORT=5173

# R3.5 — Optional same-origin reverse proxy. The `caddy` compose service
# (profiles: [proxy]) listens on this host port and routes /auth/*,
# /sync/*, /healthz to the server and everything else to the web. Only
# runs when started with `docker compose --profile proxy up`. Used for
# local Docker Desktop testing of the auth flow (cross-origin
# SameSite=Lax cookies don't work without a same-origin front door).
# Production deployments behind a host nginx leave the profile off and
# proxy directly to ${SERVER_PORT} + ${WEB_PORT} on the compose host.
PROXY_PORT=8080

# R3.5 — `WEB_ORIGIN` is the public origin the SPA is served from. The
# server's CORS allow-origin + the Auth.js redirect whitelist both gate
# on this value, and `SameSite=Lax` session cookies require the SPA's
# fetch to come from the same host as the cookie was set on. Three
# typical values:
#   - Compose with the proxy profile: `http://localhost:${PROXY_PORT}`
#     (default 8080). All traffic flows through Caddy → same origin.
#   - Compose without the proxy + host nginx in front: the public domain
#     (`https://dnd.example.com`).
#   - Compose without any proxy: `http://localhost:${WEB_PORT}` (5173).
#     This is fine for the local-only MVP but BREAKS server-mode auth
#     because the web fetches the server cross-origin.
# Leaving this blank falls back to `http://localhost:${WEB_PORT:-5173}`
# (the compose-file default) — keeps backwards-compatibility with the
# legacy local-only setup.
WEB_ORIGIN=

# R3.5 — Web bundle mode. Empty (the default) builds the web container
# in LOCAL-ONLY mode: no Login / Logout / Account / Linked accounts
# chrome appears in the UI, identical to the pre-server MVP behavior.
# Setting this to a fully-qualified origin (e.g. `https://dnd.example.com`)
# at `docker compose build` time produces a SERVER-MODE bundle that
# points the web client at that origin. The value is INLINED into the
# JS bundle by Vite — changing it requires `docker compose build web`
# (a plain `docker compose up` will keep serving the previous build).
#
# Must be SAME ORIGIN as the server in production (the session cookie
# is SameSite=Lax). With the compose `--profile proxy` setup this is
# `http://localhost:${PROXY_PORT}`. In a reverse-proxy deployment the
# value typically matches the public domain.
VITE_SERVER_URL=

# R3.2 — Auth.js (Discord OAuth + DB sessions).
# Required at all times (Auth.js refuses to start without it).
# Generate a 32+ byte random secret: `openssl rand -base64 32`.
# Rotating this invalidates ALL existing sessions per SECURITY §1.1.
AUTH_SECRET="dev-only-replace-me-with-openssl-rand-base64-32-XXXXXXXXX"

# R3.5 — Drop the `__Host-` cookie prefix + Secure flag in production. Set
# to `true` ONLY for self-hosted deployments served over plain HTTP (the
# default docker compose `--profile proxy` setup on http://localhost:8080
# is exactly this case). Without this, browsers silently refuse to store
# the session cookie on HTTP and users appear logged-out after every
# request. Real production HTTPS deployments MUST leave this blank/false.
SESSION_COOKIE_INSECURE=true

# Discord application credentials. Leave blank to disable the
# /auth/discord/* routes (they return 503) — the web Login button is
# hidden via the `GET /auth/methods` probe. In production the server
# logs a startup warning listing the missing vars but boots successfully.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback/discord

# R3.3 — Email OTP via SMTP. Same opt-in pattern as Discord: leave any of
# the five blank to disable the /auth/email/* routes (they return 503).
# Production options:
#   - Postmark / SendGrid / SES / Mailgun (set their SMTP submission host
#     + the API-key credentials they hand you)
#   - Self-hosted Postfix on the same box
# For local self-hosted testing use Mailpit (already documented in the
# server README):
#   docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=dnd-inv@localhost

# R3.4.b — nightly snapshot job. Files land in SNAPSHOT_DIR; mount it
# as a docker volume so they survive container restarts. The compose
# file does this automatically when this var is set.
SNAPSHOTS_ENABLED=true
SNAPSHOT_DIR=/data/snapshots
SNAPSHOT_RETENTION_DAYS=30
