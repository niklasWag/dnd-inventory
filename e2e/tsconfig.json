{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "noEmit": true,
    // Playwright's config + specs use `verbatimModuleSyntax`-friendly
    // imports already; keep the base's strict flags.
    "moduleResolution": "Bundler"
  },
  "include": [
    "pages/**/*.ts",
    "steps/**/*.ts",
    "tests/**/*.ts",
    "fixtures/**/*.ts",
    "playwright.config.ts"
  ]
}
