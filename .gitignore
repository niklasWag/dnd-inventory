# dependencies
node_modules/
.pnpm-store/

# build outputs
dist/
build/
*.tsbuildinfo

# test / coverage
coverage/
.nyc_output/

# editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# env / secrets
.env
.env.local
.env.*.local

# private seed content (PHB/DMG — not for redistribution, per CLAUDE.md)
packages/seeds/data/phb-*.json
packages/seeds/data/dmg-*.json

# Prisma generated client (R3.1+) — `prisma generate` output. Regenerated
# from schema.prisma; never hand-edited. Migration files in
# apps/server/prisma/migrations/ ARE committed.
apps/server/prisma/generated/

# R8.4.d — Playwright bind-mount outputs. Every `pnpm e2e` run writes
# the HTML report to `e2e/playwright-report/` and per-test artifacts
# (traces, videos, screenshots for failed specs) to `e2e/test-results/`.
# Neither belongs in git.
e2e/playwright-report/
e2e/test-results/

# R9 — design lab. A standalone, throwaway Vite app for prototyping the
# UI redesign with mock data (see docs/r9-redesign/CHARTER.md). Fully
# git-excluded: experimental scaffolding, not shipped code. Delete freely.
design-lab/

# R9 — design-doc screenshots. Excluded for now (large binaries); the
# design docs in docs/r9-redesign/*.md are the durable record.
docs/r9-redesign/drawings/
