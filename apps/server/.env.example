# Local dev defaults; production / Docker overrides these via real env vars.
# Postgres on :5433 (non-standard host port to avoid clashing with host installs).
DATABASE_URL="postgresql://dnd:dnd@localhost:5433/dnd_inv"
# Separate DB used by integration tests; created by infra/docker/postgres-init.
DATABASE_URL_TEST="postgresql://dnd:dnd@localhost:5433/dnd_inv_test"
PORT=3000
# Bind only to loopback locally so the port never leaks onto your Wi-Fi
# or VPN interface. Compose / production override to 0.0.0.0.
HOST=127.0.0.1
WEB_ORIGIN="http://localhost:5173"
LOG_LEVEL=info

# R3.2 — Auth.js (Discord OAuth + DB sessions).
# Generate a 32+ byte random secret: `openssl rand -base64 32`. SECURITY §1.1:
# rotating this invalidates ALL existing sessions (cookies become unverifiable).
AUTH_SECRET="dev-only-replace-me-with-openssl-rand-base64-32-XXXXXXXXX"

# Discord application credentials. Leave blank in dev/test to disable the
# /auth/discord/* routes (they return 503 with `discord_auth_disabled`).
# Required at boot when NODE_ENV=production — see src/config/env.ts.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:3000/auth/discord/callback"
