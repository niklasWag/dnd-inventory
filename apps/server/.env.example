# Local dev defaults; production / Docker overrides these via real env vars.
# Postgres on :5433 (non-standard host port to avoid clashing with host installs).
DATABASE_URL="postgresql://dnd:dnd@localhost:5433/dnd_inv"
# Separate DB used by integration tests; created by infra/docker/postgres-init.
DATABASE_URL_TEST="postgresql://dnd:dnd@localhost:5433/dnd_inv_test"
PORT=3000
# Bind only to loopback locally so the port never leaks onto your Wi-Fi
# or VPN interface. Compose / production override to 0.0.0.0.
HOST=127.0.0.1
WEB_ORIGIN="http://localhost:5173"
LOG_LEVEL=info

# R3.2 — Auth.js (Discord OAuth + DB sessions).
# Generate a 32+ byte random secret: `openssl rand -base64 32`. SECURITY §1.1:
# rotating this invalidates ALL existing sessions (cookies become unverifiable).
AUTH_SECRET="dev-only-replace-me-with-openssl-rand-base64-32-XXXXXXXXX"

# R3.5 — Drop the `__Host-` cookie prefix + Secure flag even in production.
# Set to "true" ONLY for self-hosted HTTP-only deployments (e.g. docker
# compose `--profile proxy` on http://localhost:8080). HTTPS production
# deployments MUST leave this blank/false.
SESSION_COOKIE_INSECURE=""

# Discord application credentials. Leave blank (or unset) to disable the
# /auth/discord/* routes (they return 503 `discord_auth_disabled`) and
# hide the Discord button on the Login screen. Production missing or
# empty values log a startup warning but do NOT crash — email-only
# deployments are first-class. See src/config/env.ts.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:3000/auth/callback/discord"

# R3.3 — Email OTP via SMTP. Leave any blank to disable the
# /auth/email/* routes (they return 503 `email_auth_disabled`) and hide
# the Email button on the Login screen. Same prod-soft-warn pattern as
# Discord — missing/empty values log a warning but don't crash boot.
# For local dev we recommend Mailpit:
#   docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# Then set SMTP_HOST=localhost / SMTP_PORT=1025 and inspect mail at
# http://localhost:8025.
SMTP_HOST=""
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="dnd-inv@localhost"

# R3.4.b — nightly snapshots. The cron fires at 03:07 local in the
# container's timezone. Disable in environments where the disk
# footprint isn't desired (the file format is identical to the web's
# JSON export, so a user-driven export is always available regardless).
SNAPSHOTS_ENABLED="true"
SNAPSHOT_DIR="./snapshots"
SNAPSHOT_RETENTION_DAYS="30"
